# 环境变量配置模板

# ============================================
# Vercel 部署配置（GitHub Actions 使用）
# ============================================
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_org_id_here
VERCEL_PROJECT_ID=your_project_id_here


# ============================================
# Tushare API 配置（必需）
# ============================================
# 注册地址：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here


# ============================================
# 股票列表配置
# ============================================
# A股股票代码列表（逗号分隔）
# 格式：上海 600000.SH，深圳 000001.SZ
STOCK_LIST=600000.SH,000001.SZ,600519.SH,000002.SZ,600036.SH,601318.SH


# ============================================
# AI 功能配置（必需）
# ============================================
# 方案一：Google Gemini（推荐，免费额度大）
# 获取地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 方案二：DeepSeek（国内友好，价格便宜）
# 获取地址：https://platform.deepseek.com/
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat


# ============================================
# 邮件通知配置（可选）
# ============================================
# QQ 邮箱 SMTP 配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_qq_mail_authorization_code

# 接收报告的邮箱地址
EMAIL_TO=receiver@example.com
